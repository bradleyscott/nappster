# Mock Mode - Set to 'true' for local dev without Supabase
# When enabled, uses in-memory mock data instead of Supabase
NEXT_PUBLIC_USE_MOCK_DATA=true

# Supabase (not needed when NEXT_PUBLIC_USE_MOCK_DATA=true)
# NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# OpenAI (still required for AI features)
OPENAI_API_KEY=your-openai-api-key
